            const calculatePercentile = (arr, percentile) => {
                if (!arr || arr.length === 0) return 0;
                const sortedArr = [...arr].sort((a, b) => a - b);
                if (percentile <= 0) return sortedArr[0];
                if (percentile >= 100) return sortedArr[sortedArr.length - 1];
                
                const index = (percentile / 100) * (sortedArr.length - 1);
                const lower = Math.floor(index);
                const upper = Math.ceil(index);

                if (lower === upper) return sortedArr[lower];

                const weight = index - lower;
                const value = sortedArr[lower] * (1 - weight) + sortedArr[upper] * weight;
                return value || 0;
            };

            function computeGlobalStatProfiles() {
                const allStats = {
                    totalDps: [], totalDamage: [], range: [], speed: [], costPerDps: []
                };

                for (const unit of Object.values(allUnitData)) {
                    if (!unit.Upgrades || unit.Upgrades.length === 0 || unit.Upgrades[0].Damage === undefined) continue;
                    
                    const placements = unit.Max || 1;
                    const cumulativeCosts = [unit.PlacePrice || 0];
                    for (let i = 1; i < unit.Upgrades.length; i++) {
                        cumulativeCosts[i] = (cumulativeCosts[i - 1] || 0) + (unit.Upgrades[i].Price || 0);
                    }
            
                    unit.Upgrades.forEach((stats, i) => {
                        if (stats.Damage === undefined) return;

                        const totalDPS = calculateDPS(stats.Damage, stats.Cooldown) * placements;
                        if (isFinite(totalDPS) && totalDPS > 0) {
                            allStats.totalDps.push(totalDPS);
                            const costUpToSelectedLevel = cumulativeCosts[i];
                            if (costUpToSelectedLevel !== undefined) {
                                const costPerDps = costUpToSelectedLevel / totalDPS;
                                if (isFinite(costPerDps)) allStats.costPerDps.push(costPerDps);
                            }
                        }
            
                        const totalDamage = (typeof stats.Damage === 'object' ? (stats.Damage.form1 + stats.Damage.form2) / 2 : stats.Damage) * placements;
                        if (isFinite(totalDamage)) allStats.totalDamage.push(totalDamage);
            
                        const range = typeof stats.Range === 'object' ? (stats.Range.form1 + stats.Range.form2) / 2 : stats.Range;
                        if (isFinite(range)) allStats.range.push(range);
            
                        const speed = typeof stats.Cooldown === 'object' ? (stats.Cooldown.form1 + stats.Cooldown.form2) / 2 : stats.Cooldown;
                        if (isFinite(speed) && speed > 0) allStats.speed.push(speed);
                    });
                }
            
                const PERCENTILE_CAP = 98;
                const finalProfiles = {};
                for (const statName in allStats) {
                    const values = allStats[statName];
                    if (values.length > 0) {
                        finalProfiles[statName] = {
                            min: Math.min(...values),
                            max: calculatePercentile(values, PERCENTILE_CAP)
                        };
                    } else {
                        finalProfiles[statName] = { min: 0, max: 0 };
                    }
                }
                globalStatProfiles = finalProfiles;
            }
            
