                    }
                });

                multipliers.dmg *= Math.max(0, 1 + elDmgBuff);
                multipliers.cd *= Math.max(0, 1 + elCdBuff);
                multipliers.range *= Math.max(0, 1 + elRangeBuff);

                multipliers.dmg *= calculateLevelMultiplier(customLevel);

                return multipliers;
            }

            function generateUpgradeRowsAndSummary(unitData, isSecondary) {
                const hasDamage = unitData.Upgrades.some(upg => upg.Damage !== undefined);
                const hasCooldown = unitData.Upgrades.some(upg => upg.Cooldown !== undefined);
                const hasRange = unitData.Upgrades.some(upg => upg.Range !== undefined);

                const hasBoostStats = unitData.Upgrades.some(upg => upg.DamageBoost || upg.CooldownBoost || upg.RangeBoost);
                const hasDpsBoost = hasBoostStats && unitData.Upgrades.some(upg => upg.DamageBoost || upg.CooldownBoost);
                const typeChangesWithUpgrades = unitData.typeChangesWithUpgrades;
                const hasPerUpgradeDegrees = unitData.Upgrades.some(upg => upg.Degrees !== undefined);

                const multipliers = getGlobalBoostMultipliers(unitData.Element);
                const upgradeRows = [];
                let maxDPS = 0;

                unitData.Upgrades.forEach((upgrade, i) => {
                    const levelName = i === 0 ? 'Placement' : (i === unitData.Upgrades.length - 1 ? 'Max' : `UPG ${i}`);
                    const basePrice = i === 0 ? (unitData.PlacePrice || 0) : (upgrade.Price || 0);
                    const price = basePrice * multipliers.cost;
                    let rowData = [levelName, price.toLocaleString()];
                    if (typeChangesWithUpgrades) {
                        rowData.push(formatStat(upgrade.Type) || '-');
                    }
                    if (hasPerUpgradeDegrees) {
                        rowData.push(formatStat(upgrade.Degrees));
                    }

                    let modDmg = 0, modCd = 0, modRange = 0, dps = 0;

                    if (hasDamage) {
                        if (typeof upgrade.Damage === 'object') {
                            modDmg = {
                                form1: upgrade.Damage.form1 * multipliers.dmg,
                                form2: upgrade.Damage.form2 * multipliers.dmg
                            };
                        } else {
                            modDmg = upgrade.Damage * multipliers.dmg;
                        }
                    }

                    if (hasCooldown) {
                        const rawCd = upgrade.Cooldown !== undefined ? upgrade.Cooldown : 0;
                        if (typeof rawCd === 'object') {
                            modCd = {
                                form1: rawCd.form1 * multipliers.cd,
                                form2: rawCd.form2 * multipliers.cd
                            };
                        } else {
                            modCd = rawCd * multipliers.cd;
                        }
                    }

                    if (hasRange) {
                        const rawRange = upgrade.Range !== undefined ? upgrade.Range : 0;
                         if (typeof rawRange === 'object') {
                            modRange = {
                                form1: rawRange.form1 * multipliers.range,
                                form2: rawRange.form2 * multipliers.range
                            };
                        } else {
                            modRange = rawRange * multipliers.range;
                        }
                    }

                    if (hasDamage && hasCooldown) {
                         dps = calculateDPS(modDmg, modCd);
                         if (typeof dps === 'number' && dps > maxDPS) maxDPS = dps;
                    }

                    if (hasDamage && hasCooldown) rowData.push(formatStat(dps, 2));
                    if (hasDamage) rowData.push(formatStat(modDmg, 2));
                    if (hasCooldown) rowData.push(formatStat(modCd, 3));
                    if (hasRange) rowData.push(formatStat(modRange, 1));

                    if (hasDpsBoost) {
                        const dmgBoost = upgrade.DamageBoost || 1.0;
                        const cdBoost = upgrade.CooldownBoost || 1.0;
                        const dpsBoostPercent = (((dmgBoost / cdBoost) - 1) * 100).toFixed(1);
                        rowData.push(`${dpsBoostPercent}%`);
                    }
                    if (hasBoostStats) {
                        const boostParts = [];
                        if (upgrade.DamageBoost) boostParts.push(`${upgrade.DamageBoost}x DMG`);
                        if (upgrade.CooldownBoost) boostParts.push(`${upgrade.CooldownBoost}x CD`);
                        if (upgrade.RangeBoost) boostParts.push(`${upgrade.RangeBoost}x Range`);
                        rowData.push(boostParts.join(', '));
                    }
                    upgradeRows.push(rowData);
                });

                let summaryData = null;
                let elementalData = null;
                const maxUpgrade = unitData.Upgrades[unitData.Upgrades.length - 1];
                const hasDamageBoostStats = maxUpgrade.DamageBoost || maxUpgrade.CooldownBoost || maxUpgrade.RangeBoost;

                if (hasDamage || hasDamageBoostStats) {
                    let sHeaders = [];
                    let sRowData = [];

                    if (hasDamageBoostStats) {
                        const totalDmgBoost = maxUpgrade.DamageBoost || 1.0;
                        const totalCdBoost = maxUpgrade.CooldownBoost || 1.0;
                        const totalRangeBoost = maxUpgrade.RangeBoost || 1.0;

                        const totalDpsBoostPercent = (((totalDmgBoost / totalCdBoost) - 1) * 100).toFixed(1) + '%';
                        
                        const boostParts = [];
                        if (totalDmgBoost !== 1.0) boostParts.push(`${totalDmgBoost.toFixed(2)}x DMG`);
                        if (totalCdBoost !== 1.0) boostParts.push(`${totalCdBoost.toFixed(2)}x CD`);
                        if (totalRangeBoost !== 1.0) boostParts.push(`${totalRangeBoost.toFixed(2)}x Range`);
                        const totalBoostsString = boostParts.join(', ') || 'None';

                        if (hasDamage && hasCooldown) {
                            sHeaders = ['Total DPS', 'Total DPS Boost', 'Total Boosts'];
                            sRowData = [formatStat(maxDPS * (unitData.Max || 1), 2), totalDpsBoostPercent, totalBoostsString];
                        } else {
                            sHeaders = ['Total DPS Boost', 'Total Boosts'];
                            sRowData = [totalDpsBoostPercent, totalBoostsString];
                        }
                    } else if (hasDamage && hasCooldown) {
                        sHeaders = ['Total DPS'];
                        sRowData = [formatStat(maxDPS * (unitData.Max || 1), 2)];
                    }
                    
                    if (sHeaders.length > 0) {
                        summaryData = { headers: sHeaders, data: [sRowData] };
                    }
                    
                    if (hasDamage) {
                        const elementsToUse = getUnitElementsArray(unitData.Element);
                        const allAdvantages = {};
                        
                        elementsToUse.forEach(el => {
                            const advantages = elementalAdvantages[el]?.Boosts;
                            if (advantages) {
                                Object.entries(advantages).forEach(([enemyEl, val]) => {
                                    allAdvantages[enemyEl] = (allAdvantages[enemyEl] || 0) + (val - 1);
                                });
                            }
                        });
                        
                        const boosts = Object.entries(allAdvantages)
                            .filter(([, buff]) => Math.abs(buff) > 0.001)
                            .sort((a, b) => b[1] - a[1]);

                        if (boosts.length > 0) {
                            const eHeaders = boosts.map(([key]) => `${key} DPS`);
                            const eData = [boosts.map(([, buff]) => formatStat(maxDPS * (unitData.Max || 1) * Math.max(0, 1 + buff), 2))];
                            elementalData = { headers: eHeaders, data: eData };
                        }
                    }
                }

                let headers = ['Level', 'Cost'];
                if (typeChangesWithUpgrades) headers.push('Attack Type');
                if (hasPerUpgradeDegrees) headers.push('Degrees');
                
                if (hasDamage && hasCooldown) headers.push('DPS');
                if (hasDamage) headers.push('Damage');
                if (hasCooldown) headers.push('Cooldown');
                if (hasRange) headers.push('Range');

                if (hasDpsBoost) headers.push('DPS Boost');
                if (hasBoostStats) headers.push('Boosts');

                return { headers, rows: upgradeRows, summaryData, elementalData };
            }

            function calculateBoostedMaxStats(unit) {
                if (!unit.Upgrades || unit.Upgrades.length === 0) return null;
                const maxLevelStats = unit.Upgrades[unit.Upgrades.length - 1];
                if (maxLevelStats.Damage === undefined) return null;

                const multipliers = getGlobalBoostMultipliers(unit.Element);
                const placements = unit.Max || 1;
                
                const unitElements = getUnitElementsArray(unit.Element);
                const enemyElement = selectedElementKey;
                let advBuff = 0;
                unitElements.forEach(el => {
                    if (elementalAdvantages[el]?.Boosts?.[enemyElement] !== undefined) {
                        advBuff += (elementalAdvantages[el].Boosts[enemyElement] - 1);
                    }
                });
                const elementalMultiplier = Math.max(0, 1 + advBuff);

                let finalDmg, boostedCd, boostedRange, fullDps, bestAttackTypeForSort, maxDegrees;

                if (unit.isSwitchUnit && typeof maxLevelStats.Damage === 'object') {
                    const boostedDmg1 = maxLevelStats.Damage.form1 * multipliers.dmg;
                    const boostedDmg2 = maxLevelStats.Damage.form2 * multipliers.dmg;
                    const cd1 = (typeof maxLevelStats.Cooldown === 'object') ? maxLevelStats.Cooldown.form1 : maxLevelStats.Cooldown;
                    const cd2 = (typeof maxLevelStats.Cooldown === 'object') ? maxLevelStats.Cooldown.form2 : maxLevelStats.Cooldown;
                    const boostedCd1 = cd1 * multipliers.cd;
                    const boostedCd2 = cd2 * multipliers.cd;
                    const finalDmg1 = boostedDmg1 * elementalMultiplier;
                    const finalDmg2 = boostedDmg2 * elementalMultiplier;
                    const dps1 = (cd1 <= 0 || boostedCd1 <= 0) ? 0 : finalDmg1 / boostedCd1;
                    const dps2 = (cd2 <= 0 || boostedCd2 <= 0) ? 0 : finalDmg2 / boostedCd2;

                    fullDps = ((dps1 + dps2) / 2) * placements;
                    finalDmg = { form1: finalDmg1, form2: finalDmg2 };
                    boostedCd = { form1: boostedCd1, form2: boostedCd2 };
                    
                    if (typeof maxLevelStats.Range === 'object') {
                        boostedRange = {
                            form1: maxLevelStats.Range.form1 * multipliers.range,
                            form2: maxLevelStats.Range.form2 * multipliers.range
                        };
                    } else {
                        boostedRange = maxLevelStats.Range * multipliers.range;
                    }

                    const type1 = (typeof maxLevelStats.Type === 'object') ? maxLevelStats.Type.form1 : maxLevelStats.Type;
                    const type2 = (typeof maxLevelStats.Type === 'object') ? maxLevelStats.Type.form2 : maxLevelStats.Type;
                    const deg1 = (typeof maxLevelStats.Degrees === 'object' && maxLevelStats.Degrees) ? (maxLevelStats.Degrees.form1 || 0) : (maxLevelStats.Degrees || 0);
                    const deg2 = (typeof maxLevelStats.Degrees === 'object' && maxLevelStats.Degrees) ? (maxLevelStats.Degrees.form2 || 0) : (maxLevelStats.Degrees || 0);

                    const rank1 = getTypeRank(type1, deg1);
                    const rank2 = getTypeRank(type2, deg2);

                    if (rank1 <= rank2) {
                        bestAttackTypeForSort = type1;
                        maxDegrees = deg1;
                    } else {
                        bestAttackTypeForSort = type2;
                        maxDegrees = deg2;
                    }
                } else {
                    const boostedDmg = maxLevelStats.Damage * multipliers.dmg;
                    boostedCd = maxLevelStats.Cooldown * multipliers.cd;
                    boostedRange = maxLevelStats.Range * multipliers.range;
                    finalDmg = boostedDmg * elementalMultiplier;
                    fullDps = calculateDPS(finalDmg, boostedCd) * placements;
                    bestAttackTypeForSort = unit.maxUpgradeType.split(' (')[0];
                    const degreesMatch = unit.maxUpgradeType.match(/\((\d+)/);
                    maxDegrees = degreesMatch ? parseInt(degreesMatch[1], 10) : 0;
                }

                return {
                    name: unit.Name,
                    rarity: unit.Rarity || 'N/A',
                    maxUpgradeType: unit.maxUpgradeType,
                    bestAttackTypeForSort: bestAttackTypeForSort,
                    maxDegrees: maxDegrees,
                    isSwitchUnit: !!unit.isSwitchUnit,
                    element: getUnitElementsString(unit.Element),
                    placements: placements,
                    fullDps: fullDps,
                    damage: finalDmg,
                    cd: boostedCd,
                    range: boostedRange
                };
            }

            function filterDpsRankings() {
                const filterText = unitSearchInput.value.toLowerCase().trim();
                const tableBody = document.getElementById('upgrades-tbody');
                if (!tableBody) return;

                const rows = tableBody.getElementsByTagName('tr');
                for (const row of rows) {
                    const unitName = row.dataset.unitName;
                    if (unitName && unitName.includes(filterText)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                }
            }
            
            function renderRankingsTbody(rankingsData) {
                const upgradesTbody = document.getElementById('upgrades-tbody');
                if (!upgradesTbody) return;
                
                const rowsFragment = document.createDocumentFragment();
                rankingsData.forEach((stats, index) => {
                    const rowData = [
                        index + 1,
                        stats.name,
                        stats.rarity,
                        stats.maxUpgradeType,
                        stats.element,
                        stats.placements,
                        formatStat(stats.fullDps),
                        formatStat(stats.damage),
                        formatStat(stats.cd, 3),
                        formatStat(stats.range, 1)
                    ];
                    const tr = createTableRow('td', rowData);
                    tr.dataset.unitName = stats.name.toLowerCase();
                    rowsFragment.appendChild(tr);
                });
                upgradesTbody.replaceChildren(rowsFragment);
                filterDpsRankings();
            }

            function populateRankingsTbody() {
                const rankingsData = [];
                for (const unitName in allUnitData) {
                    let unitData = allUnitData[unitName];
                    const boostedStats = calculateBoostedMaxStats(unitData);
                    if (boostedStats && boostedStats.fullDps > 0 && isFinite(boostedStats.fullDps)) {
                        rankingsData.push(boostedStats);
                    }
                }

                const getRarityRank = (rarity) => rarityOrder[rarity] || 99;

                const defaultCriteria = [
                    { key: 'fullDps', direction: 'desc' },
                    { key: 'rarity', direction: 'asc' }, 
                    { key: 'type', direction: 'asc' },
                    { key: 'range', direction: 'desc' },
                    { key: 'cd', direction: 'asc' },
                    { key: 'damage', direction: 'desc' },
                    { key: 'placements', direction: 'desc' },
                ];
                
                const primaryCriterion = { key: dpsRankingsSort.key, direction: dpsRankingsSort.direction };

                const sortCriteria = [
                    primaryCriterion,
                    ...defaultCriteria.filter(c => c.key !== primaryCriterion.key),
                    { key: 'name', direction: 'asc' }
                ];
                
                rankingsData.sort((a, b) => {
                    for (const { key, direction } of sortCriteria) {
                        let valA, valB;

                        if (key === 'type') {
                            valA = getTypeRank(a.bestAttackTypeForSort, a.maxDegrees, a.isSwitchUnit);
                            valB = getTypeRank(b.bestAttackTypeForSort, b.maxDegrees, b.isSwitchUnit);
                        } else if (key === 'rarity') {
                            valA = getRarityRank(a.rarity);
                            valB = getRarityRank(b.rarity);
                        } else {
                            valA = a[key];
                            valB = b[key];
                        }

                        let comparison = 0;
                        if (valA < valB) {
                            comparison = -1;
                        } else if (valA > valB) {
                            comparison = 1;
                        }

                        if (comparison !== 0) {
                            return direction === 'asc' ? comparison : -comparison;
                        }
                    }
                    return 0;
                });
                
                renderRankingsTbody(rankingsData);
                updateRankingsHeaderUI();
            }

            function updateRankingsHeaderUI() {
                const headerRow = document.getElementById('stats-header-row');
                if (!headerRow) return;

                headerRow.querySelectorAll('th.sortable-header').forEach(th => {
                    const indicator = th.querySelector('.sort-indicator');
                    const icon = indicator ? indicator.querySelector('i') : null;
                    if (!indicator || !icon) return;

                    if (th.dataset.sortKey === dpsRankingsSort.key) {
                        indicator.classList.add('visible');
                        icon.classList.toggle('descending', dpsRankingsSort.direction === 'desc');
                    } else {
                        indicator.classList.remove('visible');
                    }
                });
            }
            
            function persistBoostsIfEnabled() {
                if (settings.saveBoosts) {
                    settings.savedBoosts = getBoostsState();
                    saveSettings();
                }
            }
            
            function renderSummaryAndElementalContainers(primaryData, secondaryData) {
                const container = document.getElementById('bottom-stats-container');
                if (!container) return;
                container.innerHTML = '';

                if (primaryData.summaryData || (secondaryData && secondaryData.summaryData)) {
                    const summaryWrapper = createSectionWrapper(
                        () => primaryData.summaryData ? createTableNode(primaryData.summaryData.headers, primaryData.summaryData.data, false) : null,
                        () => (secondaryData && secondaryData.summaryData) ? createTableNode(secondaryData.summaryData.headers, secondaryData.summaryData.data, true) : null
                    );
                    if (summaryWrapper) container.appendChild(summaryWrapper);
                }

                if (primaryData.elementalData || (secondaryData && secondaryData.elementalData)) {
                    const elementalWrapper = createSectionWrapper(
                        () => primaryData.elementalData ? createTableNode(primaryData.elementalData.headers, primaryData.elementalData.data, false) : null,
                        () => (secondaryData && secondaryData.elementalData) ? createTableNode(secondaryData.elementalData.headers, secondaryData.elementalData.data, true) : null
                    );
                    if (elementalWrapper) container.appendChild(elementalWrapper);
                }
            }

            function updateAuxiliaryTables(currentStats, secStats) {
                const updateContainer = (id, buildFuncPrimary, buildFuncSecondary) => {
                    const container = document.getElementById(id);
                    if (!container) return;
                    const wrapper = createSectionWrapper(
                        () => buildFuncPrimary(currentStats, false),
                        () => secStats ? buildFuncSecondary(secStats, true) : null
                    );
                    if (wrapper) {
                        container.replaceChildren(wrapper);
                        container.style.display = 'contents';
                    } else {
                        container.innerHTML = '';
                        container.style.display = 'none';
                    }
                };

                const updateNoteContainer = () => {
                    const container = document.getElementById('note-container');
                    if (!container) return;
                    const wrapper = createSectionWrapper(
                        () => currentStats && currentStats.BackendNote ? createTableNode(['Note'], [[currentStats.BackendNote]], false, 'note-row') : null,
                        () => secStats && secStats.BackendNote ? createTableNode(['Note'], [[secStats.BackendNote]], true, 'note-row') : null
                    );
                    if (wrapper) {
                        container.replaceChildren(wrapper);
                        container.style.display = 'contents';
                    } else {
                        container.innerHTML = '';
                        container.style.display = 'none';
                    }
                };

                updateNoteContainer();
                updateContainer('rarity-container', buildRarityTable, buildRarityTable);
                updateContainer('value-container', buildValueTable, buildValueTable);
                updateContainer('obtainability-container', buildObtainabilityTable, buildObtainabilityTable);
                updateContainer('ability-container', buildAbilitiesTable, buildAbilitiesTable);
                
                adjustObtainabilityLayout();
            }

            function updateView() {
                if (!currentUnitName && !isDpsRankingsMode) return;
                
                if (currentUnitName) {
                    persistBoostsIfEnabled();
                }

                if (!document.getElementById('main-stats-table') && !isDpsRankingsMode) return;
                
                if (isDpsRankingsMode && !document.getElementById('main-stats-table')) {
                    renderUnitTables();
                }

                const elementDropdownTrigger = document.getElementById('elementDropdown');
                if (elementDropdownTrigger) {
                    const triggerTextSpan = elementDropdownTrigger.querySelector('.dropdown-trigger-text');
                    const triggerInput = elementDropdownTrigger.querySelector('.dropdown-trigger-input');
                    const labelText = isDpsRankingsMode ? 'Enemy Element: ' : 'Element: ';
                    
                    const currentStats = getCurrentUnitData();
                    let displayElementText = 'Neutral';
                    if (isDpsRankingsMode) {
                        displayElementText = elements[selectedElementKey] || 'Neutral';
                    } else if (currentStats) {
                        displayElementText = getUnitElementsString(currentStats.Element);
                    }

                    if (triggerTextSpan) {
                        triggerTextSpan.textContent = `${labelText}${displayElementText}`;
                    }
                    if (triggerInput) {
                        const labelSpan = elementDropdownTrigger.querySelector('.dropdown-trigger-label');
                        if (labelSpan) labelSpan.textContent = labelText;
                        triggerInput.value = displayElementText.replace(/\s*\(.*?\)/g, '');
                    }
                    
                    if (isDpsRankingsMode) {
                        elementDropdownTrigger.style.pointerEvents = 'auto';
                        elementDropdownTrigger.style.opacity = '1';
                        elementDropdownTrigger.style.cursor = 'pointer';
                        elementDropdownTrigger.tabIndex = 0;
                        if (triggerInput) triggerInput.disabled = false;
                    } else {
                        elementDropdownTrigger.style.pointerEvents = 'none';
                        elementDropdownTrigger.style.opacity = '0.6';
                        elementDropdownTrigger.style.cursor = 'not-allowed';
                        elementDropdownTrigger.tabIndex = -1;
                        if (triggerInput) triggerInput.disabled = true;
                    }
                }

                document.querySelectorAll('.aux-table').forEach(el => {
                    el.style.display = isDpsRankingsMode ? 'none' : '';
                });
                
                const statsHeaderRow = document.getElementById('stats-header-row');
                const upgradesTbody = document.getElementById('upgrades-tbody');
                if (!statsHeaderRow || !upgradesTbody) return;

                if (isDpsRankingsMode) {
                    const secTable = document.getElementById('main-stats-table-secondary');
                    if (secTable) secTable.remove();

                    statsHeaderRow.innerHTML = ''; 
                    const sortKeyMap = { 
                        'Full DPS': 'fullDps', 
                        'Rarity': 'rarity', 
                        'Type': 'type', 
                        'Element': 'element', 
                        'Placements': 'placements', 
                        'Damage': 'damage', 
                        'CD': 'cd', 
                        'Range': 'range' 
                    };
                    const rankingHeaders = ['Rank', 'Name', 'Rarity', 'Type', 'Element', 'Placements', 'Full DPS', 'Damage', 'CD', 'Range'];
                    
                    rankingHeaders.forEach(headerText => {
                        const th = document.createElement('th');
                        const sortKey = sortKeyMap[headerText];
                        const contentWrapper = document.createElement('div');
                        const textSpan = document.createElement('span');
                        textSpan.textContent = headerText;
                        contentWrapper.appendChild(textSpan);

                        if (sortKey && headerText !== 'Rank') {
                            th.classList.add('sortable-header');
                            th.dataset.sortKey = sortKey;
                            contentWrapper.classList.add('sortable-header-content');
                            
                            const indicator = document.createElement('span');
                            indicator.className = 'sort-indicator';
                            indicator.innerHTML = '<i class="fas fa-caret-up"></i>';
                            
                            contentWrapper.appendChild(indicator);

                            th.addEventListener('click', () => {
                                if (dpsRankingsSort.key === sortKey) {
                                    dpsRankingsSort.direction = dpsRankingsSort.direction === 'asc' ? 'desc' : 'asc';
                                } else {
                                    dpsRankingsSort.key = sortKey;
                                    dpsRankingsSort.direction = (sortKey === 'rarity' || sortKey === 'type' || sortKey === 'element' || sortKey === 'cd') ? 'asc' : 'desc';
                                }
                                populateRankingsTbody();
                            });
                        }
                        th.appendChild(contentWrapper);
                        statsHeaderRow.appendChild(th);
                    });
                    
                    const elementHeaderCell = document.getElementById('element-header-cell');
                    const boostHeaderCell = document.getElementById('boost-header-cell');
