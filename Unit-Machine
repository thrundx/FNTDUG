                const parts = valueStr.split('-').map(p => parseFloat(p.trim()));
                if (parts.some(isNaN)) return valueStr;

                const formattedParts = parts.map(formatter);
                const suffix1Match = formattedParts[0].match(/[a-zA-Z]+$/);
                const suffix2Match = formattedParts[1].match(/[a-zA-Z]+$/);
                const suffix1 = suffix1Match ? suffix1Match[0] : '';
                const suffix2 = suffix2Match ? suffix2Match[0] : '';

                if (suffix1 === suffix2 && suffix1 !== '') {
                    const num1 = formattedParts[0].replace(suffix1, '');
                    const num2 = formattedParts[1].replace(suffix2, '');
                    return `${num1}-${num2}${suffix1}`;
                }
                return formattedParts.join('-');
