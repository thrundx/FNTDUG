                        boostHeaderCell.colSpan = rankingHeaders.length;
                    }

                    populateRankingsTbody();
                } else {
                    const stats = getCurrentUnitData();
                    if (!stats) return;
                    
                    const secStats = (isCompareMode && secondaryUnitName && allUnitData[secondaryUnitName]) 
                        ? allUnitData[secondaryUnitName] 
                        : null;

                    updateAuxiliaryTables(stats, secStats);

                    const primaryData = generateUpgradeRowsAndSummary(stats, false);
                    const secondaryData = secStats ? generateUpgradeRowsAndSummary(secStats, true) : null;

                    const primaryTbodyRef = document.getElementById('upgrades-tbody');
                    const primaryHeaderRef = document.getElementById('stats-header-row');
                    if (primaryTbodyRef && primaryHeaderRef) {
                        primaryHeaderRef.replaceChildren(...primaryData.headers.map(h => { const th = document.createElement('th'); th.textContent = h; return th; }));
                        primaryTbodyRef.replaceChildren(...primaryData.rows.map(r => createTableRow('td', r)));
                    }

                    const secondaryTbodyRef = document.getElementById('upgrades-tbody-secondary');
                    const secondaryHeaderRef = document.getElementById('stats-header-row-secondary');
                    if (secondaryTbodyRef && secondaryHeaderRef && secondaryData) {
                        secondaryHeaderRef.replaceChildren(...secondaryData.headers.map(h => { const th = document.createElement('th'); th.textContent = h; return th; }));
                        secondaryTbodyRef.replaceChildren(...secondaryData.rows.map(r => createTableRow('td', r)));
                    }

                    const elementHeaderCell = document.getElementById('element-header-cell');
                    const boostHeaderCell = document.getElementById('boost-header-cell');
                    if (primaryHeaderRef && elementHeaderCell && boostHeaderCell) {
                        const columnCount = primaryData.headers.length;
                        elementHeaderCell.colSpan = columnCount;
                        boostHeaderCell.colSpan = columnCount;
                    }

                    renderSummaryAndElementalContainers(primaryData, secondaryData);
                }
            }

            function adjustObtainabilityLayout() {
                document.querySelectorAll('.obtainability-table').forEach(table => {
                    if (!table || !table.dataset.methods) return;
                    const methods = JSON.parse(table.dataset.methods);
                    const thead = table.querySelector('thead');
                    const tbody = table.querySelector('tbody');
                    
                    if (!thead || !tbody || methods.length === 0) return;

                    thead.innerHTML = '';
                    tbody.innerHTML = '';

                    const isMobileView = window.innerWidth < 768;

                    if (isMobileView || methods.length === 1) {
                        thead.appendChild(createTableRow('th', ['Obtainability']));
                        methods.forEach(method => {
                            tbody.appendChild(createTableRow('td', [method], 'note-row'));
                        });
                    } else {
                        const headerRow = createTableRow('th', ['Obtainability']);
                        headerRow.firstElementChild.colSpan = methods.length;
                        thead.appendChild(headerRow);
                        tbody.appendChild(createTableRow('td', methods, 'note-row'));
                    }
                });
            }

            function setDropdownMinWidths() {
                const ruler = document.createElement('span');
                ruler.style.cssText = 'visibility:hidden; position:absolute; white-space:nowrap; font-size:16px; padding:10px;';
