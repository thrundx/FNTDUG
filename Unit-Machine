            function processUnitData(unit) {
                const processed = { ...unit };
                let rarity = unit.Rarity;
                if (rarity === 'Mythical') rarity = 'Mythic';
                processed.Rarity = rarity;

                const upgrades = [];
                const isSwitchUnit = unit.UpgradeStats && !Array.isArray(unit.UpgradeStats) && Object.keys(unit.UpgradeStats).length > 1;

                const baseUpgrade = {
                    ...unit.BaseStats,
                    Price: 0,
                    Type: unit.BaseStats.Type || unit.Type,
                    Degrees: unit.BaseStats.Degrees || unit.Degrees
                };
                upgrades.push(baseUpgrade);

                if (isSwitchUnit) {
                    processed.isSwitchUnit = true;
                    const formKeys = Object.keys(unit.UpgradeStats);
                    const form1Key = formKeys[0], form2Key = formKeys[1];
                    const numUpgrades = unit.UpgradeStats[form1Key]?.length || 0;

                    let lastFullUpgrade = baseUpgrade;
                    let lastType1, lastDegrees1, lastType2, lastDegrees2;

                    if (typeof lastFullUpgrade.Type === 'object') {
                        lastType1 = lastFullUpgrade.Type.form1;
                        lastType2 = lastFullUpgrade.Type.form2;
                    } else {
                        lastType1 = lastType2 = lastFullUpgrade.Type;
                    }
                    if (typeof lastFullUpgrade.Degrees === 'object') {
                        lastDegrees1 = lastFullUpgrade.Degrees.form1;
                        lastDegrees2 = lastFullUpgrade.Degrees.form2;
                    } else {
                        lastDegrees1 = lastDegrees2 = lastFullUpgrade.Degrees;
                    }

                    for (let i = 0; i < numUpgrades; i++) {
                        const upg1 = unit.UpgradeStats[form1Key][i] || {};
                        const upg2 = unit.UpgradeStats[form2Key][i] || {};
                        const combinedUpgrade = { Price: upg1.UpgradePrice ?? upg2.UpgradePrice ?? 0 };

                        ['Damage', 'Cooldown', 'Range', 'DamageBoost', 'CooldownBoost', 'RangeBoost'].forEach(stat => {
                            const lastStatVal = lastFullUpgrade[stat];
                            let prevVal1 = lastStatVal, prevVal2 = lastStatVal;
                            if(typeof lastStatVal === 'object' && lastStatVal !== null) {
                                prevVal1 = lastStatVal.form1;
                                prevVal2 = lastStatVal.form2;
                            }
                            const finalVal1 = (upg1[stat] !== undefined) ? upg1[stat] : prevVal1;
                            const finalVal2 = (upg2[stat] !== undefined) ? upg2[stat] : prevVal2;

                            if (finalVal1 === finalVal2) {
                                combinedUpgrade[stat] = finalVal1;
                            } else if (finalVal1 !== undefined || finalVal2 !== undefined) {
                                combinedUpgrade[stat] = { form1: finalVal1, form2: finalVal2 };
                            }
                        });

                        const currentType1 = upg1.Type || lastType1;
                        let currentDegrees1;
                        if (upg1.Type && upg1.Type !== lastType1) {
                            currentDegrees1 = upg1.Degrees;
                        } else {
                            currentDegrees1 = upg1.Degrees !== undefined ? upg1.Degrees : lastDegrees1;
                        }

                        const currentType2 = upg2.Type || lastType2;
                        let currentDegrees2;
                        if (upg2.Type && upg2.Type !== lastType2) {
                            currentDegrees2 = upg2.Degrees;
                        } else {
                            currentDegrees2 = upg2.Degrees !== undefined ? upg2.Degrees : lastDegrees2;
                        }

                        if (currentType1 === currentType2) combinedUpgrade.Type = currentType1;
                        else combinedUpgrade.Type = { form1: currentType1, form2: currentType2 };
                        
                        if (currentDegrees1 === currentDegrees2) {
                            combinedUpgrade.Degrees = currentDegrees1;
                        } else if (currentDegrees1 !== undefined || currentDegrees2 !== undefined) {
                            combinedUpgrade.Degrees = { form1: currentDegrees1, form2: currentDegrees2 };
                        }
                        
                        upgrades.push(combinedUpgrade);
                        lastFullUpgrade = combinedUpgrade;
                        lastType1 = currentType1; lastDegrees1 = currentDegrees1;
                        lastType2 = currentType2; lastDegrees2 = currentDegrees2;
                    }
                } else {
                    if (unit.UpgradeStats && Array.isArray(unit.UpgradeStats)) {
                        let lastStats = { ...baseUpgrade };
                        unit.UpgradeStats.forEach(upg => {
                            const currentType = upg.Type || lastStats.Type;
                            let currentDegrees;
                            if (upg.Type && upg.Type !== lastStats.Type) {
                                currentDegrees = upg.Degrees;
                            } else {
                                currentDegrees = upg.Degrees !== undefined ? upg.Degrees : lastStats.Degrees;
                            }
                            
                            const newStats = {
                                ...lastStats,
                                ...upg,
                                Price: upg.UpgradePrice || 0,
                                Type: currentType,
                                Degrees: currentDegrees
                            };
                            upgrades.push(newStats);
                            lastStats = newStats;
                        });
                    }
                }
                processed.Upgrades = upgrades;
                
                const pathTypes = [];
                let lastPathTypeStr = '';
                let lastMaxUpgradeStr = '';

                processed.Upgrades.forEach(upg => {
                    let currentTypeStr = formatStat(upg.Type);
                    let currentDegreesStr = formatStat(upg.Degrees);
                    let fullTypeStr = currentTypeStr;

                    if (currentTypeStr.includes('/')) {
                        const [type1, type2] = currentTypeStr.split('/');
                        let deg1, deg2;
                        if (currentDegreesStr.includes('/')) {
                            [deg1, deg2] = currentDegreesStr.split('/');
                        } else {
                            deg1 = deg2 = currentDegreesStr;
                        }
                        
                        let part1 = type1;
                        if (deg1 !== '-') part1 += ` (${deg1}°)`;
                        let part2 = type2;
                        if (deg2 !== '-') part2 += ` (${deg2}°)`;
                        fullTypeStr = part1 === part2 ? part1 : `${part1}/${part2}`;
                    } else if (currentDegreesStr !== '-') {
                        fullTypeStr += ` (${currentDegreesStr}°)`;
                    }
                    
                    if (fullTypeStr && fullTypeStr !== lastPathTypeStr) {
                        pathTypes.push(fullTypeStr);
                        lastPathTypeStr = fullTypeStr;
                    }
                    lastMaxUpgradeStr = fullTypeStr;
                });

                processed.Type = pathTypes.join(' - ');
                processed.maxUpgradeType = lastMaxUpgradeStr;

                const allTypes = processed.Upgrades.map(upg => formatStat(upg.Type));
                const uniqueTypes = new Set(allTypes);
                processed.typeChangesWithUpgrades = uniqueTypes.size > 1;

                return processed;
            }

            (async function fetchData() {
                try {
                    const GITHUB_IMAGES_URL = 'https://raw.githubusercontent.com/UGAccount/FNTD2/main/Images';

                    const [statsResponse, imagesResponse] = await Promise.all([
                        fetch(GITHUB_URL),
                        fetch(GITHUB_IMAGES_URL)
                    ]);

                    if (!statsResponse.ok) throw new Error(`HTTP error fetching stats! status: ${statsResponse.status}`);
                    if (!imagesResponse.ok) throw new Error(`HTTP error fetching images! status: ${imagesResponse.status}`);
                    
                    const responseData = await statsResponse.json();
                    const imagesData = await imagesResponse.json();
                    
                    const rawUnitImages = imagesData.Images.Units || {};
                    unitImages = {};
                    for (const [name, url] of Object.entries(rawUnitImages)) {
                        unitImages[normalizeUnitName(name)] = url;
                    }

                    const rawSkinImages = imagesData.Images.Skins || {};
                    skinImages = {};
                    for (const [name, url] of Object.entries(rawSkinImages)) {
                        skinImages[normalizeUnitName(name)] = url;
                    }
                    
                    const rawEnchantData = responseData.Enchants;
                    enchantMultipliers = {
                        None: { dmg: 1.0, cd: 1.0, range: 1.0, cost: 1.0 }
                    };
                    for (const enchantName in rawEnchantData) {
                        const boost = rawEnchantData[enchantName].Boost;
                        if (boost) {
                            enchantMultipliers[enchantName] = {
                                dmg: boost.Damage || 1.0,
                                cd: boost.Cooldown || 1.0,
                                range: boost.Range || 1.0,
                                cost: boost.Cost || 1.0
                            };
                        }
                    }
                    enchants = generateOptionsObject(enchantMultipliers);

                    const unitValues = responseData.Values.Units || {};
                    const devValues = responseData.Values.Dev || {};
                    const rawUnitData = responseData.Units;
                    const finalUnitData = {};
                    rawUnitData.forEach(unit => {
                        if (unit.Name.startsWith('Shiny ')) return;
                        const processedUnit = processUnitData(unit);
                        finalUnitData[unit.Name] = {
                            ...processedUnit,
                            PlacePrice: unit.PlacementPrice,
                            Max: unit.MaxPlaced,
                            Passives: unit.Passives || {},
                            Actives: unit.Actives || [],
                            Obtainability: unit.Obtainability,
                            Skins: unit.Skins,
                            Value: unitValues[unit.Name] || null,
                            DevValue: devValues[unit.Name] || null,
                            BackendNote: unit.Note || undefined,
                        };
                    });
                    
                    allUnitData = finalUnitData;
                    
                    fuse = new Fuse(Object.keys(allUnitData), { threshold: 0.3 });
                    processAndStoreBoosterData();
                    computeGlobalStatProfiles();
                    loadSettings();
                    populateGallery();
                    updateSortButtonsUI();

                    if (ENABLE_URL_ROUTING) {
                        const path = window.location.pathname.replace(/\/$/, '');
                        const pathSlug = decodeURIComponent(path.substring(1));

                        const urlParams = new URLSearchParams(window.location.search);
                        const compareSlug = urlParams.get('compare');
                        if (compareSlug) {
                            const secName = Object.keys(allUnitData).find(n => createUnitSlug(n) === compareSlug);
                            if (secName) {
                                secondaryUnitName = secName;
                                isCompareMode = true;
                                compareContainer.classList.remove('hidden');
                                toggleCompareBtn.classList.add('active');
                                compareSearchInput.value = secName;
                            }
                        }

                        if (pathSlug === 'dps-list') {
                            setTimeout(() => {
                                const firstUnit = Object.keys(allUnitData)[0];
                                selectAndDisplayUnit(firstUnit, selectedVersionKey, true);
                                setupDpsRankingsView();
                            }, 0);
                        } else if (pathSlug && pathSlug !== 'unit-machine') {
                            const unitNameFromUrl = Object.keys(allUnitData).find(
                                name => createUnitSlug(name) === pathSlug
                            );
                            if (unitNameFromUrl) {
                                const versionFromStorage = sessionStorage.getItem('selectedVersion') || selectedVersionKey;
                                sessionStorage.removeItem('selectedVersion');
                                setTimeout(() => {
                                    selectAndDisplayUnit(unitNameFromUrl, versionFromStorage, true);
                                }, 0);
                            }
                        }
                    }

                } catch (error) {
                    console.error("Error fetching data:", error);
                    unitStatsContainer.innerHTML = `<p>Failed to load required data: ${error.message}</p>`;
                }
            })();

            if (ENABLE_URL_ROUTING && sessionStorage.getItem('scrollToTopOnLoad') === 'true') {
